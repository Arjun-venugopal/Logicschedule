PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
JWT_SECRET=<your-jwt-secret>
# Frontend origin for CORS (production)
# Set this to your deployed frontend URL. Supports comma-separated list for multiple origins.
FRONTEND_URL=https://your-frontend.vercel.app

# Default administrator credentials for setup scripts (production ready)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@12345
